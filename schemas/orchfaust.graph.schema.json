{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OrchFaustGraph",
  "type": "OBJECT",
  "properties": {
    "version": {
      "type": "INTEGER",
      "minimum": 1
    },
    "name": {
      "type": "STRING"
    },
    "nodes": {
      "type": "ARRAY",
      "items": {
        "type": "OBJECT",
        "properties": {
          "id": {
            "type": "STRING"
          },
          "type": {
            "type": "STRING",
            "enum": [
              "sine", "saw", "square", "noise", "gain", "lowpass", "highpass", "delay",
              "adsr", "lfo", "mixer", "reverb", "karplus_string", "modal_resonator", "body_resonator",
              "velocity", "release_velocity", "aftertouch", "note_pressure", "channel_pressure",
              "pitch_bend", "note_pitch", "channel_pitch_bend", "timbre", "expression",
              "note_number", "note_frequency", "gate", "cc", "vst_dial", "debug", "output",
              "convolution", "body_convolution", "group", "bowed_string", "clarinet", "brass",
              "flute", "guitar", "nylon_guitar", "electric_guitar", "marimba", "djembe"
            ]
          },
          "params": {
            "type": "OBJECT",
            "additionalProperties": {
              "type": "NUMBER"
            }
          },
          "stringParams": {
            "type": "OBJECT",
            "additionalProperties": {
              "type": "STRING"
            }
          }
        },
        "required": ["id", "type"]
      }
    },
    "connections": {
      "type": "ARRAY",
      "items": {
        "type": "OBJECT",
        "properties": {
          "source": {
            "type": "STRING"
          },
          "target": {
            "type": "STRING"
          }
        },
        "required": ["source", "target"]
      }
    },
    "output": {
      "type": "STRING"
    }
  },
  "required": ["version", "nodes", "connections", "output"]
}
